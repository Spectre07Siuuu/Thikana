# ─── Database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=thikana_db

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── Server ──────────────────────────────────────────────
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── Email (SMTP) — leave empty to use Ethereal test mail ─
# Get a free Ethereal test account at https://ethereal.email
# Or use Gmail, Resend, SendGrid, Mailgun, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Thikana" <noreply@thikana.com>
